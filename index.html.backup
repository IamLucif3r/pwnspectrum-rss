    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #121212;
            --text-primary: #00ff41;
            --text-secondary: #00d9ff;
            --text-muted: #888;
            --border-color: #1a1a1a;
        }

        body {
            font-family: 'Fira Code', monospace;
            background: var(--bg-primary);
            color: #ccc;
            line-height: 1.8;
            overflow-x: hidden;
        }

        /* Particle Network Background */
        #particle-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            filter: blur(2px);
            opacity: 0.3;
        }

        /* Main Container */
        .container {
            position: relative;
            z-index: 1;
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 2px solid var(--border-color);
        }

        .logo {
            font-size: 32px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: 8px;
            margin-bottom: 10px;
            text-shadow: 0 0 20px var(--text-primary);
        }

        .tagline {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 5px;
        }



        .author {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 15px;
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .social-links a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
        }

        .social-links a:hover {
            color: var(--text-primary);
            text-shadow: 0 0 10px var(--text-primary);
            transform: translateY(-2px);
        }

        .social-links svg {
            transition: all 0.3s ease;
        }

        .social-links a:hover svg {
            filter: drop-shadow(0 0 8px var(--text-primary));
        }

        /* Greeting Section */
        .greeting {
            font-size: 16px;
            line-height: 1.8;
            color: #fff;
            margin-bottom: 50px;
            padding: 20px;
            background: var(--bg-secondary);
            border-left: 4px solid var(--text-primary);
        }

        /* Category Section */
        .category {
            margin-bottom: 60px;
        }

        .category-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 30px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
            font-family: 'Fira Code', monospace;
        }

        .category-number {
            color: var(--text-secondary);
            margin-right: 10px;
        }

        /* Article */
        .article {
            margin-bottom: 0;
            padding: 20px 0;
            border-bottom: 1px solid var(--border-color);
            transition: all 0.3s ease;
        }

        .article:last-child {
            border-bottom: none;
        }

        .article:hover {
            padding-left: 10px;
            background: rgba(0, 255, 65, 0.02);
        }

        .article-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 15px;
        }

        .article-commentary {
            font-size: 14px;
            line-height: 1.8;
            color: #ddd;
            margin-bottom: 15px;
        }

        .article-link {
            font-size: 12px;
            color: var(--text-secondary);
            display: inline-block;
            text-decoration: none;
            transition: all 0.3s ease;
            word-break: break-all;
        }

        .article-link:hover {
            color: var(--text-primary);
            text-shadow: 0 0 10px var(--text-primary);
        }

        .article-meta {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 10px;
            display: flex;
            gap: 15px;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 40px 20px;
            margin-top: 80px;
            border-top: 2px solid var(--border-color);
            color: var(--text-muted);
            font-size: 12px;
        }

        .footer-author {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 10px;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 15px;
        }

        .footer-links a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .footer-links a:hover {
            color: var(--text-primary);
            text-shadow: 0 0 10px var(--text-primary);
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .logo {
                font-size: 24px;
                letter-spacing: 4px;
            }

            .greeting {
                font-size: 14px;
            }

            .category-title {
                font-size: 16px;
            }

            .article-title {
                font-size: 14px;
            }
        }

        /* Smooth Scroll */
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>

